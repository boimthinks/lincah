---
interface Props {
  items: string[];
}
const { items } = Astro.props as Props;
---
{items && items.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {items.map((district) => (
      <span class="bg-slate-100 text-slate-700 text-xs font-medium px-3 py-1.5 border border-slate-200">
        {district}
      </span>
    ))}
  </div>
)}
