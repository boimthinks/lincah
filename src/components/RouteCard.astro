---
interface Props {
  route: {
    id: string;
    data: {
      from: string;
      to: string;
      price: number;
      duration: string;
      departureTimes: string[];
      description?: string;
    };
  };
  cityImages: Record<string, string>;
}

const { route, cityImages } = Astro.props;
const { from, to, price, duration, departureTimes } = route.data;

const capitalize = (str: string) => str.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

const slugFrom = from.toLowerCase().replace(/\s+/g, '-').replace(/[()]/g, '');
const slugTo = to.toLowerCase().replace(/\s+/g, '-').replace(/[()]/g, '');
const img = cityImages[slugTo] || cityImages[slugFrom] || "/img/travel-icon.webp";
---

<a href={`/${slugFrom}/${slugTo}`} class="bg-blue-900 border border-blue-800 rounded overflow-hidden shadow-lg hover:shadow-xl hover:bg-blue-950 transition-all duration-300 flex flex-col sm:flex-row gap-6 p-6 my-8 block">
  <div class="w-full sm:w-48 h-32 flex-shrink-0 bg-blue-800">
    <img src={img} alt={`Rute ${capitalize(from)} ke ${capitalize(to)}`} class="w-full h-full object-cover rounded" />
  </div>
  
  <div class="flex flex-col justify-center flex-grow">
    <h3 class="text-xl font-black text-white uppercase tracking-tight leading-none mb-4 flex items-center gap-3">
      <span>{capitalize(from)}</span>
      <span class="text-yellow-400">&rarr;</span>
      <span>{capitalize(to)}</span>
    </h3>
    
    <div class="grid grid-cols-2 gap-4 mb-4">
      <div>
        <span class="block text-[10px] font-bold text-blue-300 uppercase tracking-wider">Tarif</span>
        <span class="text-lg font-extrabold text-yellow-400">Rp {price.toLocaleString('id-ID')}</span>
      </div>
      <div>
        <span class="block text-[10px] font-bold text-blue-300 uppercase tracking-wider">Durasi</span>
        <span class="text-lg font-bold text-white">{duration}</span>
      </div>
    </div>
    
    <div class="flex flex-wrap gap-2">
      {departureTimes.map((time: string) => (
        <span class="bg-blue-800 text-blue-100 text-[10px] font-bold px-2 py-1 border border-blue-700">
          {time}
        </span>
      ))}
    </div>
  </div>
</a>