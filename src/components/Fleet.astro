---
import { CheckCircle2, User, Sparkles } from 'lucide-react';

interface Vehicle {
  id: string;
  name: string;
  capacity: number;
  features: string[];
  image: string;
  description: string;
}

interface Props {
  vehicles: Vehicle[];
}

const { vehicles } = Astro.props;
---

<section id="fleet" class="py-20 sm:py-28 bg-slate-50 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    {/* Header Title */}
    <div class="text-center max-w-3xl mx-auto mb-16 sm:mb-20">
      <span class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest text-blue-700 bg-blue-50 px-3.5 py-2 border border-blue-200 rounded-none mb-3">
        ARMADA EKSEKUTIF PRIMA
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-blue-900 tracking-tight uppercase">
        Pilihan Armada Kelas Eksekutif & Nyaman
      </h2>
      <p class="text-base sm:text-lg text-slate-500 mt-4 leading-relaxed font-normal">
        Kami hanya mengoperasikan kendaraan bersuspensi prima, kabin bersih steril, AC dingin, dan dilengkapi charger HP di setiap kursi. Rasakan perjalanan sekelas mobil pribadi.
      </p>
    </div>

    {/* Fleet Grid presentation */}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 text-left">
      {vehicles.map((vehicle) => {
        return (
          <div
            class="bg-white rounded-none border border-slate-200 hover:border-blue-500 overflow-hidden shadow-sm transition-all duration-300 flex flex-col justify-between"
          >
            {/* Vehicle photo frame */}
            <div class="relative h-56 sm:h-64 overflow-hidden bg-slate-250">
              <img
                src={vehicle.image}
                alt={vehicle.name}
                referrerpolicy="no-referrer"
                class="w-full h-full object-cover object-center transform hover:scale-110 transition-transform duration-500"
              />
              
              {/* Status pills or capacity badge */}
              <div class="absolute top-4 left-4 bg-blue-900 text-white text-[10px] uppercase font-bold tracking-wider px-3 py-1.5 rounded-none flex items-center gap-1.5 shadow-md">
                <User class="w-3.5 h-3.5 text-yellow-400" />
                <span>Maks {vehicle.capacity} Kursi</span>
              </div>

              {vehicle.id === 'hiace-premio' && (
                <div class="absolute top-4 right-4 bg-yellow-400 text-blue-900 text-[10px] font-extrabold px-3 py-1.5 rounded-none uppercase tracking-wider flex items-center gap-1 shadow-md">
                  <Sparkles class="w-3.5 h-3.5 text-blue-900" />
                  REKOMENDASI
                </div>
              )}
            </div>

            {/* Card Content block */}
            <div class="p-6 sm:p-8 space-y-6 flex-grow flex flex-col justify-between">
              <div class="space-y-3">
                <h3 class="text-xl font-black text-blue-900 tracking-tight uppercase">{vehicle.name}</h3>
                <p class="text-xs sm:text-sm text-slate-500 leading-relaxed font-normal">
                  {vehicle.description}
                </p>
              </div>

              {/* Amenities features Bullet lists */}
              <div class="space-y-2 pt-2">
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Fasilitas Kabin:</span>
                <ul class="grid grid-cols-2 gap-2 text-xs text-slate-600 font-medium">
                  {vehicle.features.map((feat) => (
                    <li class="flex items-center gap-1.5">
                      <CheckCircle2 class="w-3.5 h-3.5 text-blue-700 flex-shrink-0" />
                      <span class="truncate">{feat}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            {/* Subfooter action info */}
            <div class="p-6 sm:p-8 bg-slate-50 border-t border-slate-200 flex items-center justify-between text-[11px] font-bold uppercase tracking-wider mt-auto leading-none">
              <span class="text-slate-500 flex items-center gap-1.5">
                <span class="w-1.5 h-1.5 bg-blue-700 rounded-none block"></span> Siap Jalan Harian
              </span>
              <a
                href="#booking-form-anchor"
                class="text-blue-700 hover:text-blue-900 font-extrabold flex items-center gap-1 transition-colors"
              >
                Booking Armada &rarr;
              </a>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>
