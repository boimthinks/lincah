---
const phoneIntl = '+6281369231893';
const waUrl = `https://wa.me/${phoneIntl}`;
const encodedText = encodeURIComponent('Halo Lincah Travel, saya ingin konsultasi.');
const defaultHref = `${waUrl}?text=${encodedText}`;

const CTAS = [
  'Butuh travel door-to-door dari Palembang? Klik WA, kami bantu booking!',
  'Mau cek jadwal keberangkatan terbaru? Tanya langsung ke admin Lincah Travel.',
  'Punya rencana perjalanan dinas atau liburan? Konsultasi rute gratis, yuk!',
  'Butuh travel dari Palembang ke Lampung, Jambi, atau Baturaja? Kami siap bantu.',
  'Mau booking kursi untuk perjalanan besok? Admin kami siap layani 24/7.',
  'Penasaran sama tarif terbaru Lincah Travel? Klik WA, kami kirim info lengkapnya.',
  'Perjalanan keluarga atau rombongan? Hiace Premio kami siap antar sampai tujuan.',
  'Butuh travel privat yang lebih nyaman? Innova Reborn bisa jadi pilihan tepat.',
  'Mau tanya rute lain selain yang ada di website? Langsung chat admin saja.',
  'Ada jadwal keberangkatan yang ingin dikonfirmasi? Kami cekkan sekarang.',
];
---

<div id="floating-wa" class="floating-wa">
  <div id="wa-bubble" class="wa-bubble hidden">
    <p id="wa-bubble-text" class="wa-bubble-text"></p>
    <div class="wa-bubble-arrow"></div>
  </div>
  <a
    id="wa-button"
    href={defaultHref}
    target="_blank"
    rel="noopener noreferrer"
    class="wa-button"
    aria-label="WhatsApp Lincah Travel"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>
</div>

<style>
  .floating-wa {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 12px;
  }

  .wa-button {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #1e3a8a;
    box-shadow: 0 4px 16px rgba(30, 58, 138, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
    flex-shrink: 0;
  }

  .wa-button:hover {
    transform: scale(1.08);
    box-shadow: 0 6px 24px rgba(30, 58, 138, 0.5);
  }

  .wa-bubble {
    position: relative;
    background: #1e3a8a;
    border: 1px solid #1e3a8a;
    border-radius: 16px;
    padding: 14px 18px;
    max-width: 300px;
    box-shadow: 0 8px 32px rgba(30, 58, 138, 0.2);
    will-change: transform, opacity;
  }

  .wa-bubble.entering {
    animation: bubbleEnter 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .wa-bubble.exiting {
    animation: bubbleExit 0.6s cubic-bezier(0.55, 0, 1, 0.45) forwards;
  }

  .wa-bubble.hidden {
    opacity: 0;
    transform: scale(0);
    transform-origin: bottom right;
    pointer-events: none;
  }

  .wa-bubble-text {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    color: #ffffff;
  }

  .wa-bubble-arrow {
    position: absolute;
    bottom: -8px;
    right: 22px;
    width: 14px;
    height: 14px;
    background: #1e3a8a;
    border-right: 1px solid #1e3a8a;
    border-bottom: 1px solid #1e3a8a;
    transform: rotate(45deg);
    clip-path: polygon(0 0, 100% 0, 100% 100%);
  }

  @keyframes bubbleEnter {
    0% {
      opacity: 0;
      transform: scale(0.15) translateY(32px);
      transform-origin: bottom right;
    }
    50% {
      opacity: 1;
      transform: scale(1.08) translateY(-4px);
      transform-origin: bottom right;
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
      transform-origin: bottom right;
    }
  }

  @keyframes bubbleExit {
    0% {
      opacity: 1;
      transform: scale(1) translateY(0);
      transform-origin: bottom right;
    }
    100% {
      opacity: 0;
      transform: scale(0.1) translateY(28px);
      transform-origin: bottom right;
    }
  }
</style>

<script>
  const CTAS = [
    'Butuh travel door-to-door dari Palembang? Klik WA, kami bantu booking!',
    'Mau cek jadwal keberangkatan terbaru? Tanya langsung ke admin Lincah Travel.',
    'Punya rencana perjalanan dinas atau liburan? Konsultasi rute gratis, yuk!',
    'Butuh travel dari Palembang ke Lampung, Jambi, atau Baturaja? Kami siap bantu.',
    'Mau booking kursi untuk perjalanan besok? Admin kami siap layani 24/7.',
    'Penasaran sama tarif terbaru Lincah Travel? Klik WA, kami kirim info lengkapnya.',
    'Perjalanan keluarga atau rombongan? Hiace Premio kami siap antar sampai tujuan.',
    'Butuh travel privat yang lebih nyaman? Innova Reborn bisa jadi pilihan tepat.',
    'Mau tanya rute lain selain yang ada di website? Langsung chat admin saja.',
    'Ada jadwal keberangkatan yang ingin dikonfirmasi? Kami cekkan sekarang.',
  ];

  const bubble = document.getElementById('wa-bubble');
  const textEl = document.getElementById('wa-bubble-text');
  let currentIndex = -1;
  let scheduleTimeout: ReturnType<typeof setTimeout> | null = null;

  function pickRandomIndex() {
    let next = Math.floor(Math.random() * CTAS.length);
    if (next === currentIndex && CTAS.length > 1) {
      next = (next + 1) % CTAS.length;
    }
    return next;
  }

  function setText(index: number) {
    if (textEl) {
      textEl.textContent = CTAS[index];
    }
  }

  function showBubble() {
    if (!bubble) return;
    currentIndex = pickRandomIndex();
    setText(currentIndex);
    bubble.classList.remove('hidden', 'exiting');
    bubble.classList.add('entering');

    if (scheduleTimeout) clearTimeout(scheduleTimeout);
    scheduleTimeout = setTimeout(hideBubble, 5000);
  }

  function hideBubble() {
    if (!bubble) return;
    bubble.classList.remove('entering');
    bubble.classList.add('exiting');

    if (scheduleTimeout) clearTimeout(scheduleTimeout);
    scheduleTimeout = setTimeout(finishExit, 600);
  }

  function finishExit() {
    if (!bubble) return;
    bubble.classList.remove('exiting');
    bubble.classList.add('hidden');

    if (scheduleTimeout) clearTimeout(scheduleTimeout);
    scheduleTimeout = setTimeout(showBubble, 3000);
  }

  const button = document.getElementById('wa-button');

  if (button) {
    button.addEventListener('click', () => {
      if (bubble) bubble.classList.remove('entering', 'exiting');
      if (scheduleTimeout) clearTimeout(scheduleTimeout);
    });
  }

  setTimeout(showBubble, 5000);
</script>