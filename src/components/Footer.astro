---
import { Compass, Phone, Mail, MapPin, Instagram, Facebook, MessageCircle } from 'lucide-react';

const ADMIN_WA = '6281369231893';
---

<footer id="hubungi" class="bg-slate-950 text-white pt-16 pb-8 text-left border-t border-blue-900 relative overflow-hidden">
  {/* Background glow shadow effects */}
  <div class="absolute top-0 left-0 w-96 h-96 bg-blue-700/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
      
      {/* Col 1 - Brand description */}
      <div class="md:col-span-4 space-y-4">
        <div class="flex items-center space-x-2">
          <div class="flex items-center justify-center w-8 h-8 bg-blue-700 text-white rounded-none">
            <Compass class="w-4 h-4" />
          </div>
          <span class="font-extrabold text-lg tracking-tight">
            TRAVEL <span class="text-yellow-400">PALEMBANG</span>
          </span>
        </div>
        
        <p class="text-xs sm:text-sm text-slate-400 leading-relaxed font-normal">
          Layanan Biro Transportasi Travel Eksekutif Terpercaya dengan sistem antar jemput alamat (door-to-door). Melayani rute harian reguler Palembang - Baturaja, Palembang - Lampung, Palembang - Jambi & semua wilayah Sumatera Selatan.
        </p>

        {/* Social media connections */}
        <div class="flex items-center space-x-3 pt-2">
          <a href="#" class="p-2 bg-white/5 border border-white/10 rounded-none text-slate-350 hover:bg-blue-700 hover:text-white transition-all">
            <Instagram class="w-4 h-4" />
          </a>
          <a href="#" class="p-2 bg-white/5 border border-white/10 rounded-none text-slate-350 hover:bg-blue-700 hover:text-white transition-all">
            <Facebook class="w-4 h-4" />
          </a>
          <a href={`https://wa.me/${ADMIN_WA}`} class="p-2 bg-white/5 border border-white/10 rounded-none text-slate-350 hover:bg-blue-700 hover:text-white transition-all">
            <MessageCircle class="w-4 h-4" />
          </a>
        </div>
      </div>

      {/* Col 2 - Quick Links */}
      <div class="md:col-span-3 space-y-4">
        <h4 class="text-sm font-bold uppercase tracking-widest text-slate-200 border-b border-white/10 pb-2">
          Navigasi Halaman
        </h4>
        <ul class="space-y-2 text-xs sm:text-sm font-medium text-slate-450">
          <li><a href="#beranda" class="hover:text-yellow-400 transition-colors text-slate-400">Beranda</a></li>
          <li><a href="#fitur" class="hover:text-yellow-400 transition-colors text-slate-400">Keunggulan & Fasilitas</a></li>
          <li><a href="#rute" class="hover:text-yellow-400 transition-colors text-slate-400">Rute & Harga Resmi</a></li>
          <li><a href="#fleet" class="hover:text-yellow-400 transition-colors text-slate-400">Pilihan Armada</a></li>
          <li><a href="#cara-pesan" class="hover:text-yellow-400 transition-colors text-slate-400">Cara Memesan Tiket</a></li>
          <li><a href="#testimoni" class="hover:text-yellow-400 transition-colors text-slate-400">Testimoni Pelanggan</a></li>
          <li><a href="#faq" class="hover:text-yellow-400 transition-colors text-slate-400">FAQ Jasa Travel</a></li>
        </ul>
      </div>

      {/* Col 3 - Contact details */}
      <div class="md:col-span-5 space-y-4">
        <h4 class="text-sm font-bold uppercase tracking-widest text-slate-200 border-b border-white/10 pb-2">
          Hubungi Kantor Utama
        </h4>
        
        <ul class="space-y-3.5 text-xs sm:text-sm text-slate-300 font-medium">
          <li class="flex items-start gap-2.5">
            <MapPin class="w-5 h-5 text-yellow-400 flex-shrink-0 mt-0.5" />
            <span class="leading-relaxed">
              Jl. Mayor Ruslan No. 104, Duku, Kec. Ilir Timur II, Kota Palembang, Sumatera Selatan 30114
            </span>
          </li>
          
          <li class="flex items-center gap-2.5">
            <Phone class="w-4.5 h-4.5 text-yellow-400 flex-shrink-0" />
            <a href={`https://wa.me/${ADMIN_WA}`} target="_blank" rel="noopener noreferrer" class="hover:text-yellow-400 transition-colors">
              +62 812-7123-4567 (WhatsApp Reservasi)
            </a>
          </li>

          <li class="flex items-center gap-2.5">
            <Mail class="w-4.5 h-4.5 text-yellow-400 flex-shrink-0" />
            <a href="mailto:info@travelpalembang.co.id" class="hover:text-yellow-400 transition-colors">
              info@travelpalembang.co.id
            </a>
          </li>
        </ul>

        <div class="bg-white/5 border border-white/10 p-4 rounded-none text-center text-[10px] text-slate-400 leading-relaxed font-semibold">
          ⚠️ <span class="text-yellow-400">Peringatan:</span> Transaksi dan pembatalan resmi hanya dilayani melalui kontak WhatsApp Admin yang tertera di website ini demi keutuhan keamanan bersama.
        </div>
      </div>

    </div>

    {/* Outer subfooter copyrights */}
    <hr class="border-white/5 mt-16 mb-8" />
    
    <div class="flex flex-col sm:flex-row items-center justify-between text-xs text-slate-500 gap-4 font-semibold">
      <span>&copy; {new Date().getFullYear()} Lincah Travel. All rights reserved.</span>
      <div class="flex space-x-4">
        <a href="#" class="hover:text-slate-350 transition-colors">Kebijakan Privasi</a>
        <span>&bull;</span>
        <a href="#" class="hover:text-slate-350 transition-colors">Syarat & Ketentuan</a>
      </div>
    </div>

  </div>
</footer>
