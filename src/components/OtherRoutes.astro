---
import { getCollection } from 'astro:content';

interface Props {
  currentRouteId: string;
}

const { currentRouteId } = Astro.props;

const capitalize = (str: string) => str.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

const allRoutes = await getCollection('rute');
const otherRoutes = allRoutes.filter(route => route.id !== currentRouteId).slice(0, 5);
---

<div class="bg-white border border-slate-200 overflow-hidden shadow-sm p-6 lg:p-8">
  <h2 class="text-xl sm:text-2xl font-black text-blue-900 mb-6">Rute Lainnya</h2>
  <ul class="space-y-4">
    {otherRoutes.length === 0 ? (
      <p class="text-slate-600">Tidak ada rute lain yang tersedia.</p>
    ) : (
      otherRoutes.map(route => {
        const toSlug = route.data.to.toLowerCase().replace(/\s+/g, '-').replace(/[()]/g, '');
        
        return (
          <li class="flex gap-3 items-center group">
            <div class="flex-shrink-0 w-10 h-10 bg-blue-50 border border-blue-100 text-blue-700 flex items-center justify-center rounded-none">
              <span class="material-icons text-xl">location_on</span>
            </div>
            <div class="flex-grow">
              <a
                href={`/${route.data.from.toLowerCase().replace(/\s+/g, '-')}/${toSlug}`}
                class="block text-slate-700 group-hover:text-blue-700 font-bold text-sm uppercase tracking-wide transition-colors"
              >
                {capitalize(route.data.from)} - {capitalize(route.data.to)}
              </a>
              <p class="text-xs font-extrabold text-blue-900 mt-0.5">
                Rp {route.data.price.toLocaleString('id-ID')}
              </p>
            </div>
          </li>
        );
      })
    )}
  </ul>
</div>
