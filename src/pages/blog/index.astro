---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.tsx';
import Footer from '../../components/Footer.astro';
import BlogHero from '../../components/BlogHero.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// Sort posts by publication date (newest first)
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Blog Perjalanan Lincah Travel Palembang";
---

<Layout title={title}>
  <Navbar client:load />
  <main>
    <BlogHero 
      title="Blog & Panduan Perjalanan" 
      subtitle="Temukan inspirasi, tips, dan panduan lengkap untuk perjalanan Anda di Sumatera Selatan dan sekitarnya." 
    />
    
    <section class="bg-white py-16 sm:py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        {/* Grid Artikel */}
        {posts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map(post => (
              <BlogCard post={post} />
            ))}
          </div>
        ) : (
          <div class="text-center py-20 bg-slate-50 border border-slate-200">
            <h3 class="text-xl font-bold text-slate-900 mb-2">Belum Ada Artikel</h3>
            <p class="text-slate-500">Artikel terbaru segera hadir. Pantau terus halaman ini untuk mendapatkan informasi dan tips perjalanan terkini!</p>
          </div>
        )}
        
      </div>
    </section>
  </main>
  <Footer />
</Layout>
