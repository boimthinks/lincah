---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/NavbarInner.tsx';
import Footer from '../../components/Footer.astro';
import BlogContent from '../../components/BlogContent.astro';
import SidebarCTA from '../../components/SidebarCTA.astro';
import BlogTOC from '../../components/BlogTOC.astro';
import { getCollection, getEntries, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const formattedDate = post.data.pubDate.toLocaleDateString('id-ID', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ADMIN_WA = '6281369231893';

// Category label mappings
const categoryLabels = {
  rute: 'Rute & Jadwal',
  armada: 'Armada Kami',
  tips: 'Tips Perjalanan',
  lokal: 'Info Lokal',
};

// Fallback image in case image_url is missing
const fallbackImage = "/img/hero_ampera_sunset_1781441848926.jpg";
const imageSrc = post.data.image_url || fallbackImage;

const pageTitle = `${post.data.judul_seo} | Blog Lincah Travel`;
---

<Layout title={pageTitle} description={post.data.description}>
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={post.data.description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={`https://lincah.web.id/blog/${post.data.slug}`} />
  <meta property="og:image" content={imageSrc.startsWith('http') ? imageSrc : `https://lincah.web.id${imageSrc}`} />
  <meta property="og:site_name" content="Lincah Travel" />
  <meta property="og:locale" content="id_ID" />
  <meta property="article:published_time" content={post.data.pubDate.toISOString()} />
  <meta property="article:modified_time" content={(post.data.updatedDate || post.data.pubDate).toISOString()} />
  <meta property="article:author" content={post.data.author} />
  <meta property="article:section" content={categoryLabels[post.data.kategori]} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={post.data.description} />
  <meta name="twitter:image" content={imageSrc.startsWith('http') ? imageSrc : `https://lincah.web.id${imageSrc}`} />

  {/* JSON-LD Schema */}
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.data.judul_seo,
    "description": post.data.description,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": (post.data.updatedDate || post.data.pubDate).toISOString(),
    "author": {
      "@type": "Organization",
      "name": "Lincah Travel"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Lincah Travel",
      "logo": {
        "@type": "ImageObject",
        "url": "https://lincah.web.id/favicon.svg"
      }
    },
    "image": imageSrc.startsWith('http') ? imageSrc : `https://lincah.web.id${imageSrc}`,
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://lincah.web.id/blog/${post.data.slug}`
    }
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Beranda",
        "item": "https://lincah.web.id/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://lincah.web.id/blog"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": post.data.title,
        "item": `https://lincah.web.id/blog/${post.data.slug}`
      }
    ]
  })} />

  <Navbar client:load />
  <main class="bg-slate-50 min-h-screen pb-24">
    
    {/* Header Artikel */}
    <div class="relative w-full h-[350px] sm:h-[450px] bg-slate-950 overflow-hidden">
      <div class="absolute inset-0">
        <img 
          src={imageSrc} 
          alt={post.data.title} 
          class="w-full h-full object-cover object-center opacity-40 scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/60 to-transparent"></div>
      </div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full flex flex-col justify-center pt-16 pb-8 sm:pt-0 sm:pb-0 text-center text-white">
        <span class="inline-block text-[10px] font-extrabold uppercase tracking-widest text-yellow-400 bg-yellow-400/10 border border-yellow-400/20 px-2 py-0.5 rounded-none mb-4 self-start w-fit">
          {categoryLabels[post.data.kategori]}
        </span>
        
        <h1 class="text-2xl sm:text-3xl lg:text-4xl font-black uppercase tracking-tight leading-tight mb-4 drop-shadow-sm max-w-4xl text-left">
          {post.data.judul_seo}
        </h1>
        
        <div class="flex flex-wrap items-center text-xs sm:text-sm text-slate-300 font-medium gap-3">
          <span>{formattedDate}</span>
        </div>
      </div>
    </div>

    {/* Breadcrumbs & Layout Grid */}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
      <nav class="flex items-center space-x-1.5 sm:space-x-2 text-[10px] sm:text-xs font-medium text-slate-500 uppercase tracking-wider pb-6">
        <a href="/" class="hover:text-blue-700 transition-colors">Lincah</a>
        <span class="text-slate-300">/</span>
        <a href="/blog" class="hover:text-blue-700 transition-colors">Blog</a>
        <span class="text-slate-300">/</span>
        <span class="text-slate-900 font-bold line-clamp-1">{post.data.title}</span>
      </nav>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        {/* Konten Utama */}
        <div class="lg:col-span-8">
          <article class="bg-transparent">
            
            {/* Gambar & Judul */}
            {imageSrc && (
              <img 
                src={imageSrc} 
                alt={post.data.title} 
                class="w-full aspect-[4/3] object-cover border border-slate-200 shadow-sm mb-8"
              />
            )}

            
            
            {/* Pengantar */}
            {post.data.pengantar && (
              <div class="mb-6 pb-6 border-b border-slate-100">
                <p class="text-slate-600 leading-relaxed">
                  {post.data.pengantar}
                </p>
              </div>
            )}

            <h2 class="text-2xl sm:text-3xl font-black text-blue-900 uppercase tracking-tight leading-tight mb-8">
              {post.data.title}
            </h2>

            {/* Isi Konten Markdown */}
            <BlogContent>
              <Content />
            </BlogContent>
            
            {/* Kesimpulan & CTA */}
            {post.data.kesimpulan && (
              <div class="mt-12 pt-8 border-t border-slate-200">
                <h2 class="text-lg font-bold text-slate-900 uppercase tracking-wide mb-4">Penutup</h2>
                <p class="text-slate-600 leading-relaxed">{post.data.kesimpulan}</p>
              </div>
            )}
            
          </article>

          {/* Back to Blog */}
          <div class="mt-8 text-left">
            <a href="/blog" class="inline-flex items-center text-xs font-bold uppercase tracking-widest text-slate-550 hover:text-blue-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
              Kembali ke Semua Artikel
            </a>
          </div>
        </div>

        {/* Sidebar */}
        <div class="lg:col-span-4 space-y-6 lg:sticky lg:top-28 h-fit">
          <SidebarCTA 
            title="Butuh Booking Travel?" 
            description="Hubungi admin Lincah Travel sekarang untuk reservasi kursi, tanya tarif promo, atau rute lainnya." 
          />
          <BlogTOC headings={headings} />
        </div>
      </div>
    </div>

  </main>
  <Footer />
</Layout>
