---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavbarInner.tsx';
import Footer from '../components/Footer.astro';
import RoutesPrices from '../components/RoutesPrices.tsx';
import { getCollection } from 'astro:content';

const routes = await getCollection('rute');
const capitalize = (str: string) => str.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

const routesData = routes.map(r => ({ 
  id: r.id, 
  ...r.data,
  from: capitalize(r.data.from),
  to: capitalize(r.data.to)
}));

const title = "Harga & Rute Travel Resmi - Lincah Travel";
---

<Layout title={title}>
  <Navbar client:load />
  <main class="pt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="text-center mb-16">
        <h1 class="text-3xl sm:text-5xl font-black text-blue-900 uppercase mb-4">
          Daftar Harga & <span class="text-blue-600">Rute Resmi</span>
        </h1>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto">
          Informasi lengkap tarif tiket flat dan jadwal keberangkatan semua rute travel eksekutif kami.
        </p>
      </div>

      <RoutesPrices routes={routesData} client:load />
    </div>
  </main>
  <Footer />
</Layout>
