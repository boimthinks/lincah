---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavbarInner.tsx';
import Footer from '../components/Footer.astro';
import RoutesPrices from '../components/RoutesPrices.tsx';
import { getCollection, getEntry } from 'astro:content';

const routes = await getCollection('rute');
const capitalize = (str: string) => str.split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');

const routesData = routes.map(r => ({ 
  id: r.id, 
  ...r.data,
  from: capitalize(r.data.from),
  to: capitalize(r.data.to)
}));

const cityImagesEntry = await getEntry('city_images', 'city-images').catch(() => null);
const cityImages = cityImagesEntry?.data.cities || {};

const title = "Harga dan Rute Lincah Travel Palembang";
---

<Layout title={title}>
  <Navbar client:load />
  <main>
    <section class="relative min-h-[60vh] flex items-center justify-center pt-32 pb-20 bg-slate-950 overflow-hidden text-center">
      <div class="absolute inset-0">
        <img
          src="/src/assets/images/hero_ampera_sunset_1781441848926.jpg"
          alt="Background Rute"
          class="w-full h-full object-cover object-top opacity-30 scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/95 via-transparent to-slate-950/30"></div>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-light text-white tracking-tight leading-tight uppercase mb-6">
          <span class="font-extrabold text-yellow-400">Harga dan Rute</span> Lincah Travel Palembang
        </h1>
        
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto font-normal leading-relaxed mb-10">
          Informasi lengkap tarif tiket flat dan jadwal keberangkatan semua rute travel eksekutif kami.
        </p>
      </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <RoutesPrices routes={routesData} cityImages={cityImages} client:load />
    </div>
  </main>
  <Footer />
</Layout>
