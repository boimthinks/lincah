---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/NavbarInner.tsx';
import Footer from '../components/Footer.astro';
import Fleet from '../components/Fleet.astro';
import { getCollection } from 'astro:content';

const vehicles = await getCollection('vehicles');
const vehiclesData = vehicles.map(v => ({ id: v.id, ...v.data }));

const title = "Rental Mobil Palembang - Sewa Mobil Lepas Kunci & Driver";
---

<Layout title={title}>
  <Navbar client:load />
  <main>
    <section class="relative min-h-[60vh] flex items-center justify-center pt-32 pb-20 bg-slate-950 overflow-hidden text-center">
      <div class="absolute inset-0">
        <img
          src="/img/hero_ampera_sunset_1781441848926.jpg"
          alt="Background Rental"
          class="w-full h-full object-cover object-top opacity-30 scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/80 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-slate-950/95 via-transparent to-slate-950/30"></div>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-light text-white tracking-tight leading-tight uppercase mb-6">
          <span class="font-extrabold text-yellow-400">Rental Mobil</span> Palembang Terpercaya
        </h1>
        
        <p class="text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto font-normal leading-relaxed mb-10">
          Layanan sewa mobil harian, mingguan, dan bulanan. Tersedia pilihan lepas kunci atau dengan driver profesional.
        </p>

        <div class="flex flex-col sm:flex-row justify-center gap-4">
          <a href="https://wa.me/6281369231893?text=Halo%20Admin%2C%20saya%20ingin%20tanya%20info%20rental%20mobil." class="bg-yellow-400 hover:bg-yellow-300 text-blue-950 font-extrabold uppercase tracking-widest text-xs px-6 py-4 rounded-none shadow-md transition-all flex items-center justify-center">
            Pesan Sekarang
          </a>
          <a href="#pilihan-mobil" class="bg-blue-700 hover:bg-blue-800 text-white font-extrabold uppercase tracking-widest text-xs px-6 py-4 rounded-none border border-blue-600 transition-colors flex items-center justify-center">
            Lihat Armada
          </a>
        </div>
      </div>
    </section>

    <div id="pilihan-mobil">
      <Fleet vehicles={vehiclesData} />
    </div>

    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-black text-blue-900 uppercase mb-6">Kenapa Rental di Tempat Kami?</h2>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 bg-blue-100 text-blue-700 flex items-center justify-center font-bold">✓</span>
                <div>
                  <span class="font-bold text-slate-800 block">Kondisi Mobil Prima</span>
                  <span class="text-slate-500 text-sm">Semua unit selalu dalam perawatan rutin dan kebersihan terjaga.</span>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 bg-blue-100 text-blue-700 flex items-center justify-center font-bold">✓</span>
                <div>
                  <span class="font-bold text-slate-800 block">Harga Kompetitif</span>
                  <span class="text-slate-500 text-sm">Tarif sewa yang transparan dan terjangkau untuk semua kalangan.</span>
                </div>
              </li>
              <li class="flex items-start gap-3">
                <span class="w-6 h-6 bg-blue-100 text-blue-700 flex items-center justify-center font-bold">✓</span>
                <div>
                  <span class="font-bold text-slate-800 block">Layanan 24 Jam</span>
                  <span class="text-slate-500 text-sm">Tim kami siap membantu Anda kapan saja dibutuhkan.</span>
                </div>
              </li>
            </ul>
          </div>
          <div class="bg-slate-50 p-8 border border-slate-200">
            <h3 class="text-xl font-bold text-blue-900 uppercase mb-4">Butuh Penawaran Khusus?</h3>
            <p class="text-slate-600 mb-6">Hubungi admin kami untuk mendapatkan harga spesial untuk sewa jangka panjang atau kebutuhan perusahaan.</p>
            <a href="https://wa.me/6281369231893" class="inline-block w-full text-center bg-blue-700 text-white font-bold py-4 hover:bg-blue-800 transition-all">HUBUNGI WHATSAPP</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
